# Project Doom — environment variables (copy to .env for local dev; set these in Vercel for prod)
# NEVER commit the real .env — it is gitignored.

# ── LLM provider (at least one). The swarm falls through Gemini → NVIDIA → Fireworks. ──
GOOGLE_API_KEY=
NVIDIA_API_KEY=
OPENAI_API_KEY=
FIREWORKS_API_KEY=

# ── Optional: live grounding + telemetry ──
TAVILY_API_KEY=
PHOENIX_API_KEY=
PHOENIX_COLLECTOR_ENDPOINT=
ELASTIC_CLOUD_ID=
ELASTIC_API_KEY=

# ── Alert system: email (Resend) ──
RESEND_API_KEY=
# Optional; defaults to Resend's no-domain sender (onboarding@resend.dev)
ALERT_FROM_EMAIL=

# ── Alert system: subscription store (Upstash Redis) ──
# The Vercel Marketplace Upstash integration injects these automatically.
KV_REST_API_URL=
KV_REST_API_TOKEN=

# ── Alert system: cron protection (Vercel auto-sends this to /api/cron_scan) ──
CRON_SECRET=
